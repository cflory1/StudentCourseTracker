@model IEnumerable<StudentCourseTracker.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<div style="background-color: #1F4E79; color: white; padding: 30px; text-align: center; margin-bottom: 20px; border-radius: 8px;">
    <h1 style="margin: 0;">Students</h1>
    <p style="margin: 5px 0 0 0; opacity: 0.8;">Manage student records</p>
</div>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Enrollment Date</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FirstName</td>
                <td>@item.LastName</td>
                <td>@item.Email</td>
                <td>@item.EnrollmentDate.ToShortDateString()</td>
                <td>@item.Status</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>