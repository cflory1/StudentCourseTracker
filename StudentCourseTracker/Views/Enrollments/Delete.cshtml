@model StudentCourseTracker.Models.Enrollment

@{
    ViewData["Title"] = "Delete Enrollment";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this enrollment?</h3>
<div>
    <h4>Enrollment Details</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Student</dt>
        <dd class="col-sm-10">@Model.Student?.FirstName @Model.Student?.LastName</dd>

        <dt class="col-sm-2">Course</dt>
        <dd class="col-sm-10">@Model.Course?.CourseName</dd>

        <dt class="col-sm-2">Date Enrolled</dt>
        <dd class="col-sm-10">@Model.DateEnrolled.ToShortDateString()</dd>

        <dt class="col-sm-2">Grade</dt>
        <dd class="col-sm-10">@Model.Grade</dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>